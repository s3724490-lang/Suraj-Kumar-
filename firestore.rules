rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isPlayer(gameData) {
      return isAuthenticated() && (request.auth.uid == gameData.whiteId || request.auth.uid == gameData.blackId);
    }
    
    function isValidGameCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['whiteId', 'whiteName', 'fen', 'pgn', 'status', 'createdAt', 'updatedAt']) &&
             data.whiteId == request.auth.uid &&
             data.status == 'waiting' &&
             data.fen is string && data.fen.size() > 0 && data.fen.size() < 200 &&
             data.pgn is string && data.pgn.size() < 10000 &&
             data.whiteName is string && data.whiteName.size() > 0 && data.whiteName.size() < 50;
    }
    
    function isValidGameUpdate() {
      let data = request.resource.data;
      let oldData = resource.data;
      
      // Allow a second player to join
      let isJoining = oldData.status == 'waiting' && data.status == 'active' && 
                      !('blackId' in oldData) && 'blackId' in data && data.blackId == request.auth.uid;
                      
      // Allow a player to make a move
      let isMoving = oldData.status == 'active' && isPlayer(oldData) &&
                     data.fen is string && data.fen.size() > 0 && data.fen.size() < 200 &&
                     data.pgn is string && data.pgn.size() < 10000 &&
                     data.whiteId == oldData.whiteId &&
                     data.blackId == oldData.blackId; // Player IDs must not change
                     
      // Allow draw offers and resignations
      let isDrawOrResign = oldData.status == 'active' && isPlayer(oldData) &&
                           data.whiteId == oldData.whiteId &&
                           data.blackId == oldData.blackId;
                           
      return isJoining || isMoving || isDrawOrResign;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /games/{gameId} {
      // Anyone authenticated can read games (to spectate or find waiting games)
      allow read: if isAuthenticated();
      
      // Any authenticated user can create a game
      allow create: if isAuthenticated() && isValidGameCreate();
      
      // Only players can update the game (join or move)
      allow update: if isAuthenticated() && isValidGameUpdate();
      
      // No one can delete games
      allow delete: if false;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
                      request.resource.data.keys().hasAll(['text', 'senderId', 'senderName', 'createdAt']) &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() > 0 &&
                      request.resource.data.text.size() < 500 &&
                      request.resource.data.senderName is string &&
                      request.resource.data.senderName.size() < 50;
        allow update, delete: if false;
      }
    }
  }
}
